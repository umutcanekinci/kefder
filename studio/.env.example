SANITY_STUDIO_PROJECT_ID=your_project_id
SANITY_STUDIO_DATASET=production

# Opsiyonel: `sanity deploy` icin tarayici yerine token (sanity.io/manage -> Account -> API -> Tokens)
# SANITY_AUTH_TOKEN=

# Opsiyonel: `npm run seed` ile ornek icerik (proje -> API -> Tokens, Editor yetkisi)
# SANITY_API_WRITE_TOKEN=
